# Frontend — copy to .env only if you need to override the API origin.
# By default the app calls same-origin /api (Vite proxies it to the local API
# server in dev; Vercel rewrites /api/* to the serverless function in prod), so
# you usually do NOT need to set this. Set it only if the API is on another host.
# VITE_API_URL=https://your-api-host.example.com/api
