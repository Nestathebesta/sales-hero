# Backend — copy to server/.env and adjust for your environment
PORT=3001

# Vercel AI Gateway (War Council AI coaching).
# Create server/.env (gitignored) and paste your key here — NEVER commit it,
# and never put it in a VITE_/frontend var (those ship to the browser).
# Without a key the War Council still works via a built-in rule-based fallback.
AI_GATEWAY_API_KEY=
# Optional overrides:
# AI_GATEWAY_MODEL=openai/gpt-4o-mini
# AI_GATEWAY_URL=https://ai-gateway.vercel.sh/v1/chat/completions
# AI_GATEWAY_TIMEOUT_MS=12000
