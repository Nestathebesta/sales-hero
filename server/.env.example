# Backend — copy to server/.env and adjust for your environment
PORT=3001

# Persistence: set BOTH to use Supabase; leave blank to fall back to data.json
# (local dev works with no config). The service-role key is a SECRET — never
# commit it and never expose it to the browser. In production set these as
# environment variables on your host (e.g. Vercel project settings).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel AI Gateway (War Council AI coaching).
# Create server/.env (gitignored) and paste your key here — NEVER commit it,
# and never put it in a VITE_/frontend var (those ship to the browser).
# Without a key the War Council still works via a built-in rule-based fallback.
AI_GATEWAY_API_KEY=
# Optional overrides:
# AI_GATEWAY_MODEL=openai/gpt-4o-mini
# AI_GATEWAY_URL=https://ai-gateway.vercel.sh/v1/chat/completions
# AI_GATEWAY_TIMEOUT_MS=12000

# Structured planner sync (app-native MCP client; see docs/integrations.md §4).
# Leave STRUCTURED_MCP_URL blank to keep the poller disabled (server runs fine).
# Set it to Structured's MCP endpoint to have THIS server pull tasks directly and
# award XP on completion — no Claude in the loop. STRUCTURED_MCP_TOKEN is the
# bearer token for that endpoint (if it uses static-token auth).
STRUCTURED_MCP_URL=
STRUCTURED_MCP_TOKEN=
# STRUCTURED_SYNC_INTERVAL_MIN=60   # poll cadence in minutes (min 5, default 60)
# STRUCTURED_TZ=America/Chicago     # timezone for get_today
